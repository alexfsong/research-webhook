# Webhook env — copy to .env and edit. Loaded by webhook.py at startup.
# Already-set env vars (e.g. from systemd) are NOT overridden.

# --- Required ---
# Bearer token for all /endpoints (except /health). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_API_KEY=

# --- Required for /research_fire (gap-fill flow) ---
# OAT token for the ingest-research Claude Code Routine. From Routines settings.
ANTHROPIC_OAT=
# /fire URL for the ingest-research routine. Shown after creating it in Routines.
ROUTINE_RESEARCH_FIRE_URL=
# Beta header — bump when Anthropic changes the routines API version.
# ROUTINE_FIRE_BETA=experimental-cc-routine-2026-04-01
# Eviction TTL for completed runs (seconds).
# RESEARCH_RUN_TTL=3600

# --- LangGraph (for /research → deep-research agent) ---
# LANGGRAPH_URL=http://127.0.0.1:2024
# LANGGRAPH_ASSISTANT=Deep Researcher
# RUN_TIMEOUT_SECONDS=1800

# --- LlamaIndex retrieval ---
# LLAMAINDEX_ENABLED=true
# LI_COLLECTION=research_li
# LI_EMBED_MODEL=BAAI/bge-small-en-v1.5
# LI_RERANK_MODEL=BAAI/bge-reranker-base
# LI_RERANK_TOP_N=5
# LI_RETRIEVE_TOP_K=20
# LI_CHUNK_SIZE=512
# LI_CHUNK_OVERLAP=64

# --- HuggingFace model cache ---
# HF_HOME=/home/researcher/research-data/hf-cache

# --- Graph-RAG (PropertyGraphIndex) — off by default ---
# LI_GRAPH_ENABLED=false

# --- /synthesize2 LLM rate limit ---
# SYNTHESIS_MODEL=claude-sonnet-4-6
# SYNTHESIS_RATE_PER_MIN=10

# --- Course generation models ---
# COURSE_PLAN_MODEL=claude-sonnet-4-6
# COURSE_LESSON_MODEL=claude-sonnet-4-6
# COURSE_CLAIMS_MODEL=claude-haiku-4-5-20251001
# COURSE_ASK_MODEL=claude-sonnet-4-6
# COURSE_CORPUS_K=30
# COURSE_LESSON_K=10
# COURSE_ASK_K=8

# --- Anthropic API key (for course gen + Q&A + deep-research orchestrator) ---
ANTHROPIC_API_KEY=

# --- Ask depth tiers (standard / deep) ---
# Rollback flag — false short-circuits /ask back to today's single-pass behavior.
# ASK_DEPTH_ENABLED=true
# Standard tier (single-pass, matches today's defaults).
# ASK_DEPTH_STANDARD_MAX_SEARCHES=1
# ASK_DEPTH_STANDARD_MAX_FETCHES=5
# ASK_DEPTH_STANDARD_MAX_TOKENS=8000
# ASK_DEPTH_STANDARD_MAX_ITERATIONS=1
# Deep tier (iterative gap loop; minutes per run, materially higher Anthropic + web cost).
# ASK_DEPTH_DEEP_MAX_SEARCHES=8
# ASK_DEPTH_DEEP_MAX_FETCHES=25
# ASK_DEPTH_DEEP_MAX_TOKENS=80000
# ASK_DEPTH_DEEP_MAX_ITERATIONS=8
# Per-bearer per-day cap on deep submissions enqueued (over → 429 deep_daily_cap).
# ASK_DEPTH_DEEP_MAX_PER_DAY=20
# Optional: dedicated routine fire URL for deep (in-process orchestrator if unset).
# ROUTINE_ASK_DEEP_FIRE_URL=
# Deep-loop synthesizer model + per-round caps.
# ASK_DEPTH_DEEP_MODEL=claude-sonnet-4-6
# ASK_DEPTH_DEEP_PER_QUERY_K=6
# ASK_DEPTH_DEEP_ROUND_MAX_TOKENS=4096
# ASK_DEPTH_DEEP_PER_SNIPPET=500
# Local webhook URL used by the deep orchestrator to POST /ask_callback.
# WEBHOOK_LOCAL_URL=http://127.0.0.1:8000

# --- Deep queue + subscription auth ---
# Synthesizer backend. `subscription` = claude -p /deep-synth subprocess (charges
# the operator's Claude Pro/Max plan, no API key cost). `api` = Anthropic SDK
# with ANTHROPIC_API_KEY (for testing or when subscription path is unavailable).
# ASK_DEPTH_DEEP_BACKEND=subscription
# Subprocess wall-clock cap per /deep-synth round.
# ASK_DEPTH_DEEP_SUBPROCESS_TIMEOUT=600
# Max concurrent deep drainers across all bearers (bounds subprocess fan-out).
# ASK_DEPTH_DEEP_MAX_DRAINERS=3
